# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/equinox_db?schema=public"

# JWT Secrets (use strong random strings in production)
JWT_SECRET="equinox_jwt_secret_change_in_production_min_32_chars"
JWT_REFRESH_SECRET="equinox_refresh_secret_change_in_production_min_32_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AI — Gemini (Module 2: AI Meeting Summarizer)
# Get your free API key from https://aistudio.google.com/app/apikey
# Supported models (free tier): gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"
